# Copy from court-booking/.env — use the pooled Neon connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/mint-db?sslmode=require

# Optional
FRONTEND_URL=http://localhost:3000

# Email (Resend) — when set, emails are sent via Resend; otherwise printed to console
RESEND_SECRET=re_your_api_key_here
# Use onboarding@resend.dev for testing, or a verified domain address in production
DEFAULT_FROM_EMAIL=onboarding@resend.dev
